# --- Dán khối KEY=VALUE (bỏ dòng #) vào Portainer → Stack → Environment variables ---
# Chi tiết từng dòng sửa gì: đọc file PORTAINER-BAN-SUA-GI.txt cùng thư mục platform/

# (BẮT BUỘC ĐỔI) IP máy chạy Docker / Portainer
SERVER_IP=192.168.1.116

# Chỉ đổi nếu trùng cổng app khác — mặc định backend ra ngoài cổng 7000
BACKEND_PUBLISH_PORT=7000
FRONTEND_PUBLISH_PORT=5173
ADMINER_PUBLISH_PORT=8080

PROJECT_NAME=Vella IPTV

# (BẮT BUỘC ĐIỀN) Sinh bằng: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

POSTGRES_USER=vella
POSTGRES_DB=vella_iptv

# (BẮT BUỘC ĐIỀN) Mật khẩu PostgreSQL
POSTGRES_PASSWORD=

# (NÊN ĐỔI) Email đăng nhập dashboard
FIRST_SUPERUSER=admin@example.com

# (BẮT BUỘC ĐIỀN) Mật khẩu đăng nhập dashboard
FIRST_SUPERUSER_PASSWORD=

EMAILS_FROM_EMAIL=noreply@example.com

IMAGE_TAG=latest
