# Dán các dòng này vào Portainer → Stack → Environment variables (hoặc file .env của stack).
# Đổi giá trị; KHÔNG commit file copy thật của bạn lên Git.

SERVER_IP=192.168.1.116

# Cổng trên HOST (backend trong container vẫn 8000)
BACKEND_PUBLISH_PORT=7000
FRONTEND_PUBLISH_PORT=5173
ADMINER_PUBLISH_PORT=8080

PROJECT_NAME=Vella IPTV

# Sinh mạnh: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

POSTGRES_USER=vella
POSTGRES_DB=vella_iptv
POSTGRES_PASSWORD=

FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=

EMAILS_FROM_EMAIL=noreply@example.com

# Tuỳ chọn
IMAGE_TAG=latest
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
